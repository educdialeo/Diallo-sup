# === Console de supervision Dialeo (Diallo-sup) — exemple de configuration ===
# Copier ce fichier en .env puis adapter. Ne JAMAIS committer le .env réel.

# Nom du service, exposé tel quel par l'endpoint /health.
APP_NAME="Diallo-sup console"

# Chemin du fichier SQLite (rétention 90 j + purge nocturne — cf docs/ARCHITECTURE.md).
DATABASE_URL="sqlite:///./data/diallo_sup.db"

# Origine locale écoutée par uvicorn (derrière Cloudflare Tunnel — pas d'exposition directe).
HOST="127.0.0.1"
PORT="8000"

# Verbosité des logs : debug | info | warning | error.
LOG_LEVEL="info"

# === Auth admin (chantier 4 phase A) ===
# Secret de signature des JWT de session. Généré une fois via
# `python -m app.scripts.init_secrets` (ou automatiquement par create_admin).
# NE JAMAIS committer la vraie valeur. Sans cette variable, /api/auth/* renvoie 503.
JWT_SECRET=""

# Durée de vie de la session (heures). Défaut 12.
SESSION_TTL_HOURS="12"

# Cookie Secure : False en local HTTP. À passer à True quand l'app sera
# servie en HTTPS (derrière Cloudflare Tunnel).
SESSION_COOKIE_SECURE="false"

# === MFA TOTP (chantier 4 phase B) ===
# Clé Fernet pour chiffrer le secret TOTP en base (44 caractères base64).
# Générée par `python -m app.scripts.init_secrets`. NE JAMAIS committer.
# Si absente, /api/auth/totp/* renvoie 503 (mais /api/ingest continue).
TOTP_AT_REST_KEY=""

# Durée de vie du JWT pre_auth (étape 1/2, avant verify-totp), en minutes.
PREAUTH_TTL_MINUTES="5"

# Lockout par compte : seuil et durée.
LOGIN_MAX_ATTEMPTS="5"
LOGIN_LOCKOUT_MINUTES="15"
